    </a>
    <button class="sticky-cta-btn" id="stickyCtaBtn">Залишити заявку</button>
  </div>
</div>

<script>
(function () {
  'use strict';

  /* ── Copyright year ──────────────────────────────────────────────────── */
  var yrEl = document.getElementById('yr');
  if (yrEl) yrEl.textContent = new Date().getFullYear();

  /* ── Dynamic urgency month ───────────────────────────────────────────── */
  var months = ['січні','лютому','березні','квітні','травні','червні',
                'липні','серпні','вересні','жовтні','листопаді','грудні'];
  var currentMonth = months[new Date().getMonth()];
  document.querySelectorAll('.urgency-month').forEach(function (el) {
    el.textContent = currentMonth;
  });

  /* ── Phone validation ────────────────────────────────────────────────── */
  function isValidPhone(phone) {
    var clean = phone.replace(/[\s\-\(\)\+]/g, '');
    return /^380\d{9}$/.test(clean) || /^0\d{9}$/.test(clean);
  }

  /* ── Form submission → /api/lead ─────────────────────────────────────── */
  var form       = document.getElementById('mainForm');
  var success    = document.getElementById('formSuccess');
  var phoneInput = document.getElementById('fphone');
  var phoneError = document.getElementById('phoneError');
  var apiError   = document.getElementById('formApiError');
  var submitBtn  = document.getElementById('submitBtn');

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    /* honeypot check */
    var hp = document.getElementById('fwebsite');
    if (hp && hp.value) return;

    var phone = phoneInput.value.trim();
    if (!phone || !isValidPhone(phone)) {
      phoneError.textContent = phone
        ? 'Введіть коректний номер (+38 0XX XXX XX XX)'
        : 'Будь ласка, введіть номер телефону';
      phoneError.style.display = 'block';
      phoneInput.classList.add('error');
      phoneInput.focus();
      return;
    }
    phoneError.style.display = 'none';
    phoneInput.classList.remove('error');
    apiError.style.display = 'none';

    var data = {
      name  : document.getElementById('fname').value.trim(),
      phone : phone,
      type  : (document.querySelector('input[name="type"]:checked')  || {}).value || '',
      power : (document.querySelector('input[name="power"]:checked') || {}).value || '',
      time  : (document.getElementById('ftime') || {}).value || '',
      page  : window.location.href,
      ts    : new Date().toISOString()
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Відправляємо…';

    fetch('/api/lead', {
      method  : 'POST',
      headers : { 'Content-Type': 'application/json' },
      body    : JSON.stringify(data)
    })
    .then(function (res) {
      return res.json().then(function (json) {
        return { ok: res.ok, json: json };
      });
    })
    .then(function (result) {
      if (result.ok && result.json.success) {
        form.style.display    = 'none';
        success.style.display = 'block';
      } else {
        throw new Error(result.json.error || 'Server error');
      }
    })
    .catch(function () {
      apiError.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Отримати розрахунок безкоштовно →';
    });
  });

  phoneInput.addEventListener('input', function () {
    phoneError.style.display = 'none';
    phoneInput.classList.remove('error');
  });

  /* ── Scroll reveal (Intersection Observer) ───────────────────────────── */
  if ('IntersectionObserver' in window) {
    var revealObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });
    document.querySelectorAll('.reveal').forEach(function (el) {
      revealObs.observe(el);
    });
  } else {
    document.querySelectorAll('.reveal').forEach(function (el) {
      el.classList.add('is-visible');
    });
  }

  /* ── Counter animation ───────────────────────────────────────────────── */
  function animateCount(el) {
    var target   = parseInt(el.getAttribute('data-target'), 10);
    var suffix   = el.getAttribute('data-suffix') || '';
    var duration = 1600;
    var startTs  = null;
    function step(ts) {
      if (!startTs) startTs = ts;
      var progress = Math.min((ts - startTs) / duration, 1);
      var eased    = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target) + suffix;
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  if ('IntersectionObserver' in window) {
    var countObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          animateCount(entry.target);
          countObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(function (el) {
      countObs.observe(el);
    });
  }

  /* ── Smooth scroll ───────────────────────────────────────────────────── */
  document.querySelectorAll('a[href^="#"]').forEach(function (a) {
    a.addEventListener('click', function (e) {
      var href = this.getAttribute('href');
      if (href === '#') return;
      var target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  /* ── Sticky CTA button scroll → form ────────────────────────────────── */
  var stickyBtn = document.getElementById('stickyCtaBtn');
  stickyBtn.addEventListener('click', function () {
    var target = document.getElementById('contact');
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  /* ── Single merged scroll handler ───────────────────────────────────── */
  var stickyCta  = document.getElementById('stickyCta');
  var floatCall  = document.getElementById('floatCall');
  var nav        = document.querySelector('nav.top');
  var stickyShown = false;
  var floatShown  = false;
  var lastScrollY = 0;
  nav.style.transition = 'transform .3s ease';

  window.addEventListener('scroll', function () {
    var y = window.scrollY;

    if (y > 500 && !stickyShown) {
      stickyCta.classList.add('show');
      stickyShown = true;
    } else if (y <= 80 && stickyShown) {
      stickyCta.classList.remove('show');
      stickyShown = false;
    }

    if (y > 400 && !floatShown) {
      floatCall.classList.add('show');
      floatShown = true;
    } else if (y <= 80 && floatShown) {
      floatCall.classList.remove('show');
      floatShown = false;
    }

    nav.style.transform = (y > lastScrollY && y > 140) ? 'translateY(-100%)' : '';
    lastScrollY = y;
  }, { passive: true });

})();
</script>
</body>
</html>
